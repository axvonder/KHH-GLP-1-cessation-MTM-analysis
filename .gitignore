# macOS and Office scratch files
.DS_Store
**/.DS_Store
~$*
*.tmp
*.bak
*.log
.Rhistory
.RData
.Rproj.user/

# Temporary visual-QA render folders
rendered_*/
**/rendered_*/

# Protected study data and local source/reference documents
/*.csv
/*.xlsx
/*.xls
/*.docx
/*.pdf

# Generated pipeline outputs
/output/

# Inputs are supplied locally; keep only the folder structure in Git
/inputs/raw/*
!/inputs/raw/.gitkeep
/inputs/reference/*
!/inputs/reference/.gitkeep
